# ============================================================
# SNetS-SDM-SBRC26 - .gitignore
# Java/Maven + Python analyzer + Docker/WSL/Windows artifacts
# ============================================================

# ------------------------------------------------------------
# Java / Maven build outputs
# ------------------------------------------------------------
target/
out/
bin/
build/
dist/
*.class
*.log

# Maven temporary/release files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml

# ------------------------------------------------------------
# Eclipse / IDE files
# ------------------------------------------------------------
.classpath
.project
.settings/
.metadata/
.recommenders/
.factorypath

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.example.json

# ------------------------------------------------------------
# Python virtual environments and caches
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Python packaging/build artifacts
*.egg-info/
.eggs/
pip-wheel-metadata/
htmlcov/
.coverage
.coverage.*
.tox/
.nox/

# ------------------------------------------------------------
# Data analyzer generated outputs
# Keep repository CSV datasets/results tracked.
# Do NOT ignore *.csv globally.
# ------------------------------------------------------------
outputs/
output/
plots/
figures/
generated/
tmp/
temp/

# Common graph/export outputs generated during local review
simulations/Data_Analyzer/outputs/
simulations/Data_Analyzer/output/
simulations/Data_Analyzer/plots/
simulations/Data_Analyzer/figures/
simulations/Data_Analyzer/generated/
simulations/Data_Analyzer/tmp/
simulations/Data_Analyzer/temp/

# Optional local CLI/GUI customizations
# Keep example files tracked; ignore personal/local variants.
simulations/Data_Analyzer/settings.local.json
simulations/Data_Analyzer/config_cli.local.json
simulations/Data_Analyzer/*_local.json

# Generated images/documents from local plot tests
*.svg.tmp
*.pdf.tmp

# ------------------------------------------------------------
# Docker / compose local overrides
# ------------------------------------------------------------
docker-compose.override.yml
.docker/
.dockerignore.local

# ------------------------------------------------------------
# OS-specific files
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# Windows shortcuts and temporary files
*.lnk
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# ------------------------------------------------------------
# Secrets / credentials
# ------------------------------------------------------------
private-key-firebase.json
*firebase*.json
*.pem
*.key
*.p12
*.pfx
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Large/local archives generated during packaging
# ------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# If a specific archive is part of the artifact and must be tracked,
# add it explicitly with a negation rule, for example:
# !simulations/SNetS-SDM-SBRC26.jar

# ------------------------------------------------------------
# Local reports generated by previous audit/cleanup runs
# ------------------------------------------------------------
JAVADOC_AUDIT_REPORT*.txt
JAVADOC_AUDIT_REPORT*.csv
PORTUGUESE_SWEEP_REPORT*.txt
JAVA_SWEEP_AUDIT*.txt
